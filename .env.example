DOMAIN=httpworkbench.com
FRONTEND_URL=https://httpworkbench.com
INSTANCES_DOMAIN=instances.httpworkbench.com

API_PORT=8081
INSTANCES_PORT=8082

JWT_SECRET=your-jwt-secret-here
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
