{
  "name": "httpworkbench",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "setup": "bun run scripts/setup/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "vitest run && bun run test:bun",
    "test:bun": "cd packages/backend && bun test --isolate",
    "validate": "bun run knip && bun run lint && bun run format && bun run typecheck && bun run test",
    "dev:frontend": "bun run --filter frontend dev",
    "dev:backend": "bun run --filter backend dev",
    "knip": "knip"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@typescript/native-preview": "7.0.0-dev.20260425.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "knip": "^6.16.1",
    "prettier": "^3.8.4",
    "typescript": "~5.9.3",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "eslint-plugin-prettier": "^5.5.6",
    "picocolors": "^1.1.1"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.1.12",
    "@codemirror/language": "6.12.2",
    "@codemirror/state": "6.5.2",
    "@codemirror/view": "6.38.8",
    "zod": "4.3.6"
  }
}
